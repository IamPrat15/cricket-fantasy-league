# ─── Required ────────────────────────────────────────────────
JWT_SECRET=MyIPL2026SecretKey_ChangeThis
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourAdminPassword123
DEADLINE=2026-03-28T14:00:00.000Z

# ─── Turso Database (persistent storage — get these from turso.tech) ──────
TURSO_DB_URL=libsql://your-db-name-yourname.turso.io
TURSO_DB_TOKEN=your-turso-auth-token

# ─── Port (Render sets this automatically) ────────────────────
PORT=3000
