# Copy this to .env and fill in your values

# JWT Secret — any random string (keep it secret!)
JWT_SECRET=MyIPL2026SecretKey_ChangeThis

# Admin credentials — use these to login at /admin-login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourAdminPassword123

# Team submission deadline (UTC time)
# IST is UTC+5:30, so 7:30 PM IST = 14:00 UTC
# Format: YYYY-MM-DDTHH:MM:SS.000Z
DEADLINE=2026-03-28T14:00:00.000Z

# Port (Render sets this automatically — don't change)
PORT=3000
